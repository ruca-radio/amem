# OpenClaw Memory System - Environment Configuration

# External Ollama (optional - for using existing LAN Ollama)
# Uncomment and set to use your own Ollama instance instead of the container
OLLAMA_HOST=http://10.27.27.10:11434

# Ollama Model (default: nomic-embed-text)
# OLLAMA_MODEL=nomic-embed-text

# API Keys for cloud providers (optional)
# OPENROUTER_KEY=sk-or-...
# ANTHROPIC_KEY=sk-ant-...
# OPENAI_KEY=sk-...

# HuggingFace (optional - for local embeddings without Ollama)
# HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Memory System Configuration
# AGENT_ID=default
# OPENCLAW_WORKSPACE=~/.openclaw/workspace